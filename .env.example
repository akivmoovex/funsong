# --- Copy to .env on the server or set in your host’s environment panel. ---
# Never commit real .env values. Never log passwords or DATABASE_URL in application logs.

# Server
PORT=3000
# npm start sets NODE_ENV=production; do not override unless you know why.

# --- Required in production (app exits on startup if missing) ---
# PostgreSQL connection string (e.g. Supabase or Hostinger DB).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
# Long random string for express-session signing (not the same as a DB password).
SESSION_SECRET=replace_with_a_long_random_string

# --- Database scripts (one-time or idempotent) ---
# npm run db:migrate — needs DATABASE_URL
# npm run db:seed — also needs all three; remove credentials from shared logs after use.
# SUPER_ADMIN_EMAIL=admin@example.com
# SUPER_ADMIN_PASSWORD=use-a-long-random-secret
# SUPER_ADMIN_NAME=FunSong Admin

# Supabase / examples (uncomment and edit; do not use commented placeholders as real values):
# DATABASE_URL=postgres://USER:PASSWORD@db.PROJECT.ref.supabase.co:5432/postgres
# or pooler:
# DATABASE_URL=postgres://USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Reverse proxy (e.g. Hostinger in front of Node): set so Express sees correct client IP and secure cookies
# TRUST_PROXY=1
# If you must use non-HTTPS during testing only (not recommended in production):
# FORCE_INSECURE_COOKIE=1

# Party WebSocket: comma-separated extra origins; leave empty for same-site only. Dev uses VITE_DEV_ORIGIN from Vite.
# PARTY_SOCKET_CORS=https://your-domain.com
# CORS_ORIGINS= (optional; same-host app does not need this when API and PWA share origin)

# MP3 uploads (super admin). Default max 15 MB.
# MAX_AUDIO_UPLOAD_MB=15
# On-disk audio blobs: default is <repo>/data/audio. Use an absolute, writable path outside the web root on production.
# Example: AUDIO_STORAGE_DIR=/home/youruser/funsong-audio
