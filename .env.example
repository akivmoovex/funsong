# --- Copy to .env or .env.local for local dev. On Hostinger, set in hPanel → Node.js → Environment Variables. ---
# Never commit real .env files. Never log the full DATABASE_URL, passwords, or SESSION_SECRET in app logs.

# Local development (optional for pure UI work; required for DB-backed API and npm start in production)
# NODE_ENV=development
PORT=3000
# APP_BASE_URL=https://your-domain.com

# PostgreSQL (Supabase or any Postgres). Use sslmode=require for Supabase.
#DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#SESSION_SECRET=replace_with_long_random_string

# --- Required in production (app exits on startup if missing) ---
# Absolute path for uploaded MP3 blobs; outside the public site root. See docs/AUDIO_STORAGE_RUNBOOK.md
# AUDIO_STORAGE_DIR=/home/youruser/funsong-audio

# Optional (see README; party guest cap in V1 is set when the admin approves the request, not this var)
# MAX_AUDIO_UPLOAD_MB=15
# MAX_PARTY_GUESTS=30

# --- Database scripts (one-time) ---
# npm run db:migrate — needs DATABASE_URL
# npm run db:seed — set SUPER_ADMIN_EMAIL, SUPER_ADMIN_PASSWORD, SUPER_ADMIN_NAME; never commit real values
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace_with_strong_password
SUPER_ADMIN_NAME=Admin User

# Supabase: get the connection string from Project Settings → Database → Connection string (URI), then add ?sslmode=require if not present.
# Example shape only (placeholders, not a real project):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Reverse proxy (e.g. Hostinger in front of Node)
# TRUST_PROXY=1
# FORCE_INSECURE_COOKIE=1  # local HTTP tests only; not for production

# Party WebSocket
# PARTY_SOCKET_CORS=https://your-domain.com

# MP3 uploads (see README)
# MAX_AUDIO_UPLOAD_MB=15

# --- Rate limits (see README) ---
# RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
# RATE_LIMIT_LOGIN_MAX=20
# RATE_LIMIT_JOIN_WINDOW_MINUTES=1
# RATE_LIMIT_JOIN_MAX=60
# RATE_LIMIT_BYPASS=1
